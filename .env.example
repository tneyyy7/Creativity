VITE_SUPABASE_URL=your_project_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_GEMINI_API_KEY=your_gemini_key_here

# Public site URL — used to build referral links (?ref=code) in the admin panel.
# Defaults to https://thecreativityapp.com if unset.
VITE_PUBLIC_APP_URL=https://thecreativityapp.com

# Observability (optional — leave blank to disable; the app no-ops without them)
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
